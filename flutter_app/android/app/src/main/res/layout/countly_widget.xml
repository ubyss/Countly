<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/countly_widget_background"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="112dp">

        <ImageView
            android:id="@+id/widget_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/countly_widget_image_description"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <View
            android:id="@+id/widget_image_placeholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/countly_flip_shell"
            android:visibility="visible" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/countly_widget_image_overlay" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="12dp"
            android:background="@drawable/countly_widget_date_badge"
            android:gravity="center"
            android:minWidth="52dp"
            android:orientation="vertical"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp">

            <TextView
                android:id="@+id/widget_target_day"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="00"
                android:textColor="#FFFFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_target_month"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:letterSpacing="0.08"
                android:text="JAN"
                android:textAllCaps="true"
                android:textColor="#CCFFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_brand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:letterSpacing="0.08"
            android:text="COUNTLY"
            android:textAllCaps="true"
            android:textColor="#CCFFFFFF"
            android:textSize="10sp"
            android:textStyle="bold" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Próximo evento"
            android:textColor="@color/countly_widget_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/widget_flip_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/countly_flip_shell"
                android:orientation="vertical"
                android:padding="2dp">

                <TextView
                    android:id="@+id/widget_primary_value"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/countly_flip_top"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="00"
                    android:textColor="@color/countly_flip_top_text"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@color/countly_flip_hinge" />

                <TextView
                    android:id="@+id/widget_primary_label"
                    android:layout_width="match_parent"
                    android:layout_height="28dp"
                    android:background="@drawable/countly_flip_bottom"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:letterSpacing="0.12"
                    android:text="DIAS"
                    android:textAllCaps="true"
                    android:textColor="@color/countly_flip_bottom_text"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_secondary_flip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/countly_flip_shell"
                android:orientation="vertical"
                android:padding="2dp">

                <TextView
                    android:id="@+id/widget_secondary_value"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/countly_flip_top"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="00"
                    android:textColor="@color/countly_flip_top_text"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@color/countly_flip_hinge" />

                <TextView
                    android:id="@+id/widget_secondary_label"
                    android:layout_width="match_parent"
                    android:layout_height="28dp"
                    android:background="@drawable/countly_flip_bottom"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:letterSpacing="0.12"
                    android:text="HORAS"
                    android:textAllCaps="true"
                    android:textColor="@color/countly_flip_bottom_text"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/widget_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/countly_widget_muted"
            android:textSize="12sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_empty_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/countly_widget_empty_message"
            android:textColor="@color/countly_widget_muted"
            android:textSize="13sp"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
