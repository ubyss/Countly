<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/small_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/countly_widget_background"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="14dp">

    <TextView
        android:id="@+id/small_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/countly_widget_accent"
        android:textSize="40sp"
        android:fontFamily="sans-serif-black"
        android:includeFontPadding="false"
        android:maxLines="1" />

    <TextView
        android:id="@+id/small_unit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/countly_widget_muted"
        android:textSize="11sp"
        android:letterSpacing="0.12"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1" />

    <TextView
        android:id="@+id/small_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="@color/countly_widget_text"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/small_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/countly_widget_muted"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/small_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/countly_widget_empty_message"
        android:textColor="@color/countly_widget_muted"
        android:textSize="12sp"
        android:visibility="gone" />
</LinearLayout>
